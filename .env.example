# ═══════════════════════════════════════════════════════════
# SMK Smart SIS — Environment Configuration
# ═══════════════════════════════════════════════════════════

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smksmartsis

# Server
PORT=3000

# ═══════════════════════════════════════════════════════════
# GitHub Copilot SDK (Opsi A — LLM Provider)
# ═══════════════════════════════════════════════════════════

# Model yang digunakan (lihat: https://docs.github.com/copilot/using-github-copilot/using-claude-sonnet-in-github-copilot)
COPILOT_MODEL=claude-sonnet-4.6

# Token GitHub untuk autentikasi Copilot SDK
# Pilih salah satu:
#   1. Fine-grained PAT (github_pat_xxx) dengan permission "Copilot Requests"
#   2. OAuth token (gho_xxx) dari `copilot login`
#   3. GitHub App user-to-server token (ghu_xxx)
# Jika kosong, SDK akan coba pakai `copilot login` credentials dari keychain
COPILOT_GITHUB_TOKEN=

# Log level untuk Copilot CLI (none|error|warning|info|debug|all)
COPILOT_LOG_LEVEL=warning

# ═══════════════════════════════════════════════════════════
# Ollama (Legacy — tidak dipakai jika menggunakan Copilot SDK)
# ═══════════════════════════════════════════════════════════
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
